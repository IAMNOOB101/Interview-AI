# ── Server ────────────────────────────────────────────────────────
PORT=4000
NODE_ENV=development          # change to production in prod

# ── PostgreSQL ────────────────────────────────────────────────────
DB_NAME=interviewai
DB_USER=postgres
DB_PASS=
DB_HOST=127.0.0.1
DB_PORT=5432

# ── Auth ──────────────────────────────────────────────────────────
# Generate: openssl rand -base64 48
JWT_SECRET=

# ── Gemini AI (Google AI Studio) ──────────────────────────────────
# Get key: https://aistudio.google.com/app/apikey  (free tier: 15 rpm)
GEMINI_API_KEY=

# ── Email (Gmail App Password) ────────────────────────────────────
EMAIL_USER=your@gmail.com
EMAIL_PASS=                   # 16-char App Password from Google Account

# ── Frontend URL ──────────────────────────────────────────────────
CLIENT_URL=http://localhost:5173

# ── Razorpay (optional — payment integration) ─────────────────────
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=
